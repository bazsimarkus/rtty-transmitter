# =========================
# MPLAB X / NetBeans files
# =========================
# Private IDE settings (machine-specific and window layouts)
nbproject/private/

# Auto-generated project Makefiles and package scripts
# (MPLAB regenerates these automatically based on configurations.xml)
nbproject/Makefile-*
nbproject/Package-*.bash

# Auto-generated build flags and cache files
.generated_files/
nbactions.xml
nb-configuration.xml
funclist

# =========================
# Build output directories (DO NOT COMMIT)
# =========================
build/
dist/
debug/
nbbuild/
nbdist/
disassembly/
html/

# =========================
# Compiled / intermediate files (AVR / XC8 / GCC)
# =========================
# Object files and dependencies
*.o
*.d
*.obj
*.obj.dmp

# Binaries and executables
*.elf
*.hex
*.bin
*.srec
*.eep

# Debugging, mapping, and listing files
*.map
*.lst
*.lss
*.sym
*.sdb
*.cod
*.cof

# PIC/Legacy specific (safe to keep ignored even for AVR)
*.p1
*.p2
*.p3
*.pre

# =========================
# OS & editor junk
# =========================
Thumbs.db
Desktop.ini
.DS_Store
*~
*.swp
.vscode/
.idea/